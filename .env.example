# Database Configuration
DB_DRIVER=postgres  # Options: postgres, oracle

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hyperscal_db

# Oracle Configuration
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_USER=system
ORACLE_PASSWORD=oracle
ORACLE_SERVICE_NAME=ORCLPDB1

# Server Configuration
SERVER_PORT=8080

# JWT Configuration
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRES_IN=24

# Kafka Configuration
# ---------------------------------------------------------------
# Single broker  : KAFKA_BROKERS=localhost:9092
# Cluster brokers: KAFKA_BROKERS=broker1:9092,broker2:9092,broker3:9092
# ---------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=hyperscal-consumer-group
KAFKA_AUTO_OFFSET_RESET=earliest   # earliest | latest
KAFKA_SECURITY_PROTOCOL=PLAINTEXT  # PLAINTEXT | SSL | SASL_PLAINTEXT | SASL_SSL
